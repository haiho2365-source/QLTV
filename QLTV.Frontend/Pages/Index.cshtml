        function renderUsersPage(){
            const user = currentUser();
            if(user.role !== 'librarian') return;
            const users = getUsers().filter(u => u.role === 'user');
            const rows = users.map(u => {
                const active = getReceipts().filter(r => r.username === u.username && r.status === 'borrowing' && r.qty > r.returnedQty).length;
                const overdue = getReceipts().filter(r => r.username === u.username && r.status === 'borrowing' && r.qty > r.returnedQty && daysBetween(startOfDay(new Date()), new Date(r.dueDate + 'T00:00:00')) < 0).length;
                const fine = calculateUserFine(u.username);
                return `
                    <tr>
                        <td><b>${escapeHtml(u.username)}</b><div class="small">${escapeHtml(u.fullName || '')}</div></td>
                        <td>${escapeHtml(u.email || '-')}</td>
                        <td>${active}</td>
                        <td>${overdue}</td>
                        <td>${formatMoney(fine)}</td>
                        <td>
                            <div class="toolbar">
                                <button class="btn btn-ghost" onclick="openUserDetail('${escapeAttr(u.username)}')">Xem</button>
                                <button class="btn btn-soft" onclick="resetUserPassword('${escapeAttr(u.username)}')">Đặt lại MK</button>
                                <button class="btn btn-ghost" onclick="deleteUser('${escapeAttr(u.username)}')">Xoá</button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
            document.getElementById('workspace').innerHTML = `
                <div class="panel">
                    <div class="panel-title">
                        <h3>Quản lý người dùng</h3>
                        <button class="btn btn-primary" onclick="openUserEditor()">Thêm người dùng</button>
                    </div>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Tài khoản</th>
                                <th>Email</th>
                                <th>Đang mượn</th>
                                <th>Quá hạn</th>
                                <th>Phạt</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>${rows || '<tr><td colspan="6">Không có người dùng</td></tr>'}</tbody>
                    </table>
                </div>
            `;
        }

        function openUserEditor(username = null){
            const user = currentUser();
            if(user.role !== 'librarian') return;
            const record = username ? getUsers().find(u => u.username === username) : { username:'', fullName:'', email:'', phone:'', password:'123456' };
            state.editingUser = username;
            openModal(`
                <div class="modal-card">
                    <div class="modal-header">
                        <h3>${username ? 'Sửa người dùng' : 'Thêm người dùng'}</h3>
                        <button class="btn btn-ghost" onclick="closeModal()">Đóng</button>
                    </div>
                    <div class="form-grid">
                        <input id="userUsername" class="field" placeholder="Tên tài khoản" value="${escapeHtml(record.username || '')}" ${username ? 'readonly' : ''}>
                        <input id="userFullName" class="field" placeholder="Họ và tên" value="${escapeHtml(record.fullName || '')}">
                        <input id="userEmail" class="field" placeholder="Email" value="${escapeHtml(record.email || '')}">
                        <input id="userPhone" class="field" placeholder="Số điện thoại" value="${escapeHtml(record.phone || '')}">
                        <input id="userPassword" class="field" type="password" placeholder="Mật khẩu" value="${escapeHtml(record.password || '123456')}">
                    </div>
                    <div class="modal-actions">
                        <button class="btn btn-primary" onclick="saveUser()">Lưu</button>
                    </div>
                </div>
            `);
        }

        function saveUser(){
            const user = currentUser();
            if(user.role !== 'librarian') return;

            const username = document.getElementById('userUsername').value.trim();
            const fullName = document.getElementById('userFullName').value.trim();
            const email = document.getElementById('userEmail').value.trim();
            const phone = document.getElementById('userPhone').value.trim();
            const password = document.getElementById('userPassword').value;

            if(!username || !fullName || !password){
                alert('Vui lòng nhập đầy đủ thông tin');
                return;
            }

            const users = getUsers();
            const idx = users.findIndex(u => u.username === username);

            if(state.editingUser && idx >= 0){
                if(users[idx].role !== 'user'){
                    alert('Chỉ được sửa người dùng');
                    return;
                }
                users[idx].fullName = fullName;
                users[idx].email = email;
                users[idx].phone = phone;
                users[idx].password = password;
            }else{
                if(idx >= 0){
                    alert('Tên tài khoản đã tồn tại');
                    return;
                }
                users.push({
                    username,
                    password,
                    role:'user',
                    fullName,
                    email,
                    phone,
                    inbox:[{ text:'Tài khoản được tạo bởi thủ thư.', at:new Date().toISOString() }],
                    borrowed:[]
                });
            }

            saveUsers(users);
            closeModal();
            renderApp();
        }

        function openUserDetail(username){
            const u = getUsers().find(x => x.username === username);
            if(!u) return;
            const myReceipts = getReceipts().filter(r => r.username === username);
            const active = myReceipts.filter(r => r.status === 'borrowing');
            openModal(`
                <div class="modal-card">
                    <div class="modal-header">
                        <h3>Chi tiết người dùng</h3>
                        <button class="btn btn-ghost" onclick="closeModal()">Đóng</button>
                    </div>
                    <div class="panel" style="margin:0 0 14px">
                        <b>${escapeHtml(u.fullName || u.username)}</b>
                        <div class="small">Tài khoản: ${escapeHtml(u.username)} · Email: ${escapeHtml(u.email || '-')} · SĐT: ${escapeHtml(u.phone || '-')}</div>
                    </div>
                    <div class="panel" style="margin:0 0 14px">
                        <b>Phiếu đang mượn</b>
                        ${active.length ? active.map(r => `<div class="notice-item"><div><b>${escapeHtml(r.title)}</b></div><div class="small">${r.qty - r.returnedQty}/${r.qty} · Hẹn trả ${r.dueDate}</div></div>`).join('') : '<div class="empty">Không có</div>'}
                    </div>
                    <div class="panel" style="margin:0">
                        <b>Lịch sử phiếu</b>
                        ${myReceipts.length ? myReceipts.map(r => `<div class="notice-item"><div><b>${escapeHtml(r.title)}</b></div><div class="small">Mượn ${r.borrowDate} · Trạng thái ${escapeHtml(r.status)}</div></div>`).join('') : '<div class="empty">Không có</div>'}
                    </div>
                </div>
            `);
        }

        function resetUserPassword(username){
            const users = getUsers();
            const idx = users.findIndex(u => u.username === username);
            if(idx < 0) return;
            if(!confirm(`Đặt lại mật khẩu cho ${username} về 123456?`)) return;
            users[idx].password = '123456';
            users[idx].inbox = Array.isArray(users[idx].inbox) ? users[idx].inbox : [];
            users[idx].inbox.unshift({ text:'Mật khẩu đã được thủ thư đặt lại thành 123456.', at:new Date().toISOString() });
            saveUsers(users);
            renderApp();
        }

        function deleteUser(username){
            const current = currentUser();
            if(username === current.username) return;
            const users = getUsers();
            const u = users.find(x => x.username === username);
            if(!u) return;
            if(u.role !== 'user') return;
            if(!confirm(`Xoá tài khoản ${username}?`)) return;
            saveUsers(users.filter(x => x.username !== username));
            renderApp();
        }

        function renderStockPage(){
            const books = getBooks();
            const rows = books.map(b => `
                <tr>
                    <td><b>${escapeHtml(b.id)}</b></td>
                    <td>${escapeHtml(b.name)}</td>
                    <td>${escapeHtml(b.author)}</td>
                    <td>${escapeHtml(b.category)}</td>
                    <td>${b.quantity}</td>
                    <td>${b.total}</td>
                    <td>${b.total - b.quantity}</td>
                </tr>
            `).join('');
            document.getElementById('workspace').innerHTML = `
                <div class="panel">
                    <div class="panel-title">
                        <h3>Theo dõi tồn kho</h3>
                        <div class="small">Tổng số, còn lại và số đang mượn</div>
                    </div>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Mã</th>
                                <th>Tên sách</th>
                                <th>Tác giả</th>
                                <th>Thể loại</th>
                                <th>Còn lại</th>
                                <th>Tổng</th>
                                <th>Đang mượn</th>
                            </tr>
                        </thead>
                        <tbody>${rows}</tbody>
                    </table>
                </div>
            `;
        }

        function calculateUserFine(username){
            const receipts = getReceipts().filter(r => r.username === username);
            const today = startOfDay(new Date());
            return receipts.reduce((sum, r) => {
                if(r.status !== 'borrowing' || r.qty <= r.returnedQty) return sum;
                const remaining = r.qty - r.returnedQty;
                const overdueDays = Math.max(0, daysBetween(new Date(r.dueDate + 'T00:00:00'), today));
                return sum + overdueDays * remaining * FINE_PER_DAY;
            }, 0);
        }

        function renderLibrariansPage(){
            const user = currentUser();
            if(user.role !== 'admin') return;
            const librarians = getUsers().filter(u => u.role === 'librarian');
            const rows = librarians.map(u => {
                return `
                    <tr>
                        <td><b>${escapeHtml(u.username)}</b><div class="small">${escapeHtml(u.fullName || '')}</div></td>
                        <td>${escapeHtml(u.email || '-')}</td>
                        <td>${escapeHtml(u.phone || '-')}</td>
                        <td>
                            <div class="toolbar">
                                <button class="btn btn-ghost" onclick="openLibrarianDetail('${escapeAttr(u.username)}')">Xem</button>
                                <button class="btn btn-soft" onclick="openLibrarianEditor('${escapeAttr(u.username)}')">Sửa</button>
                                <button class="btn btn-ghost" onclick="deleteLibrarian('${escapeAttr(u.username)}')">Xoá</button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
            document.getElementById('workspace').innerHTML = `
                <div class="panel">
                    <div class="panel-title">
                        <h3>Quản lý thủ thư</h3>
                        <button class="btn btn-primary" onclick="openLibrarianEditor()">Thêm thủ thư</button>
                    </div>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Tài khoản</th>
                                <th>Email</th>
                                <th>Số điện thoại</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>${rows || '<tr><td colspan="4">Không có thủ thư nào</td></tr>'}</tbody>
                    </table>
                </div>
            `;
        }

        function openLibrarianEditor(username = null){
            const user = currentUser();
            if(user.role !== 'admin') return;
            const record = username ? getUsers().find(u => u.username === username) : { username:'', fullName:'', email:'', phone:'', password:'123456' };
            state.editingUser = username;
            openModal(`
                <div class="modal-card">
                    <div class="modal-header">
                        <h3>${username ? 'Sửa thủ thư' : 'Thêm thủ thư'}</h3>
                        <button class="btn btn-ghost" onclick="closeModal()">Đóng</button>
                    </div>
                    <div class="form-grid">
                        <input id="libUsername" class="field" placeholder="Tên tài khoản" value="${escapeHtml(record.username || '')}" ${username ? 'readonly' : ''}>
                        <input id="libFullName" class="field" placeholder="Họ và tên" value="${escapeHtml(record.fullName || '')}">
                        <input id="libEmail" class="field" placeholder="Email" value="${escapeHtml(record.email || '')}">
                        <input id="libPhone" class="field" placeholder="Số điện thoại" value="${escapeHtml(record.phone || '')}">
                        <input id="libPassword" class="field" type="password" placeholder="Mật khẩu" value="${escapeHtml(record.password || '123456')}">
                    </div>
                    <div class="modal-actions">
                        <button class="btn btn-primary" onclick="saveLibrarian()">Lưu</button>
                    </div>
                </div>
            `);
        }

        function saveLibrarian(){
            const user = currentUser();
            if(user.role !== 'admin') return;

            const username = document.getElementById('libUsername').value.trim();
            const fullName = document.getElementById('libFullName').value.trim();
            const email = document.getElementById('libEmail').value.trim();
            const phone = document.getElementById('libPhone').value.trim();
            const password = document.getElementById('libPassword').value;

            if(!username || !fullName || !password){
                alert('Vui lòng nhập đầy đủ thông tin');
                return;
            }

            const users = getUsers();
            const idx = users.findIndex(u => u.username === username);

            if(state.editingUser && idx >= 0){
                if(users[idx].role !== 'librarian'){
                    alert('Chỉ được sửa tài khoản thủ thư');
                    return;
                }
                users[idx].fullName = fullName;
                users[idx].email = email;
                users[idx].phone = phone;
                users[idx].password = password;
            }else{
                if(idx >= 0){
                    alert('Tên tài khoản đã tồn tại');
                    return;
                }
                users.push({
                    username,
                    password,
                    role:'librarian',
                    fullName,
                    email,
                    phone,
                    inbox:[{ text:'Tài khoản thủ thư được tạo bởi admin.', at:new Date().toISOString() }],
                    borrowed:[]
                });
            }

            saveUsers(users);
            closeModal();
            renderApp();
        }

        function openLibrarianDetail(username){
            const u = getUsers().find(x => x.username === username);
            if(!u) return;
            openModal(`
                <div class="modal-card">
                    <div class="modal-header">
                        <h3>Chi tiết thủ thư</h3>
                        <button class="btn btn-ghost" onclick="closeModal()">Đóng</button>
                    </div>
                    <div class="panel" style="margin:0">
                        <b>${escapeHtml(u.fullName || u.username)}</b>
                        <div class="small">Tài khoản: ${escapeHtml(u.username)}</div>
                        <div class="small">Email: ${escapeHtml(u.email || '-')}</div>
                        <div class="small">Số điện thoại: ${escapeHtml(u.phone || '-')}</div>
                    </div>
                </div>
            `);
        }

        function deleteLibrarian(username){
            if(username === 'admin') return;
            const users = getUsers();
            const u = users.find(x => x.username === username);
            if(!u || u.role !== 'librarian') return;
            if(!confirm(`Xoá thủ thư ${username}?`)) return;
            saveUsers(users.filter(x => x.username !== username));
            renderApp();
        }

        function renderReportsPage(){
            const books = getBooks();
            const receipts = getReceipts();
            const reports = getReports();
            const topBook = books.slice().sort((a,b) => (b.total - b.quantity) - (a.total - a.quantity))[0];
            const totalFine = calculateTotalFine();
            const overdue = countOverdueReceipts();
            document.getElementById('workspace').innerHTML = `
                <div class="panel">
                    <div class="panel-title">
                        <h3>Báo cáo hệ thống</h3>
                    </div>
                    <div class="subgrid">
                        <div class="card">
                            <div class="badge">Phiếu mượn</div>
                            <div class="card-title">${receipts.length}</div>
                            <div class="meta">Tổng số phiếu trong hệ thống</div>
                        </div>
                        <div class="card">
                            <div class="badge">Quá hạn</div>
                            <div class="card-title">${overdue}</div>
                            <div class="meta">Phiếu cần xử lý</div>
                        </div>
                        <div class="card">
                            <div class="badge">Tiền phạt</div>
                            <div class="card-title">${formatMoney(totalFine)}</div>
                            <div class="meta">Tạm tính theo dữ liệu hiện tại</div>
                        </div>
                        <div class="card">
                            <div class="badge">Sách mượn nhiều</div>
                            <div class="card-title">${escapeHtml(topBook ? topBook.name : '-')}</div>
                            <div class="meta">${topBook ? `Đang mượn ${topBook.total - topBook.quantity} bản` : 'Chưa có dữ liệu'}</div>
                        </div>
                    </div>
                </div>
                <div class="two-col">
                    <div class="panel">
                        <div class="panel-title">
                            <h3>Báo cáo</h3>
                          
                        </div>
                        <div class="notice-list">
                            ${reports.map(r => `
                                <div class="notice-item">
                                    <b>${escapeHtml(r.title)}</b>
                                    <div class="small">${escapeHtml(r.content)}</div>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                    <div class="panel">
                        <div class="panel-title">
                            <h3>Top sách mượn nhiều</h3>
                        </div>
                        ${books.slice().sort((a,b) => (b.total - b.quantity) - (a.total - a.quantity)).slice(0,6).map(b => `
                            <div class="notice-item">
                                <b>${escapeHtml(b.name)}</b>
                                <div class="small">Mã ${escapeHtml(b.id)} · Đã mượn ${b.total - b.quantity} bản</div>
                            </div>
                        `).join('')}
                    </div>
                </div>
            `;
        }

        function syncReminders(){
            const users = getUsers();
            const receipts = getReceipts();
            let changed = false;
            const today = startOfDay(new Date());

            receipts.forEach(r => {
                if(r.status !== 'borrowing' || r.qty <= r.returnedQty) return;
                const remaining = r.qty - r.returnedQty;
                const due = new Date(r.dueDate + 'T00:00:00');
                const daysLeft = daysBetween(today, due);
                const overdueDays = Math.max(0, -daysLeft);

                if(daysLeft >= 0 && daysLeft <= 3 && !r.noticeDueSoonSent){
                    const user = users.find(u => u.username === r.username);
                    if(user){
                        user.inbox.unshift({ text:`Nhắc nhở: sách ${r.title} sắp đến hạn trả vào ${r.dueDate}.`, at:new Date().toISOString() });
                        changed = true;
                    }
                    r.noticeDueSoonSent = true;
                }

                if(overdueDays >= 1 && (r.lastOverdueNoticeDay === 0 || overdueDays - r.lastOverdueNoticeDay >= 3)){
                    const user = users.find(u => u.username === r.username);
                    if(user){
                        user.inbox.unshift({ text:`Sách ${r.title} đã quá hạn ${overdueDays} ngày. Tiền phạt tạm tính: ${formatMoney(overdueDays * remaining * FINE_PER_DAY)}.`, at:new Date().toISOString() });
                        changed = true;
                    }
                    r.lastOverdueNoticeDay = overdueDays;
                }
            });

            if(changed){
                saveUsers(users);
                saveReceipts(receipts);
            }
        }

        function showInitialScreen(){
            initAppData();
            const user = currentUser();
            if(user){
                document.getElementById('roleScreen').classList.add('hidden');
                document.getElementById('loginScreen').classList.add('hidden');
                document.getElementById('registerScreen').classList.add('hidden');
                document.getElementById('appScreen').classList.remove('hidden');
                state.role = user.role;
                state.tab = user.role === 'user' ? 'books' : 'dashboard';
                syncReminders();
                renderApp();
            }
        }

        setInterval(() => {
            if(currentUser()) syncReminders();
        }, 60000);

        window.addEventListener('DOMContentLoaded', showInitialScreen);
    </script>
</body>
</html>