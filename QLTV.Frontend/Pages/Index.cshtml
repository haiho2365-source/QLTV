        function saveBook(){
            const user = currentUser();
            if(user.role !== 'librarian') return;

            const id = document.getElementById('bookId').value.trim();
            const name = document.getElementById('bookName').value.trim();
            const author = document.getElementById('bookAuthor').value.trim();
            const category = document.getElementById('bookCategory').value.trim();
            const total = Number(document.getElementById('bookTotal').value);
            const quantity = Number(document.getElementById('bookQuantity').value);
            const desc = document.getElementById('bookDesc').value.trim();

            if(!id || !name || !author || !category){
                alert('Vui lòng nhập đầy đủ thông tin sách');
                return;
            }
            if(!Number.isFinite(total) || total < 0 || !Number.isFinite(quantity) || quantity < 0){
                alert('Số lượng không hợp lệ');
                return;
            }
            if(quantity > total){
                alert('Số bản có sẵn không thể lớn hơn tổng số bản');
                return;
            }

            const books = getBooks();
            const idx = books.findIndex(b => b.id === id);

            if(state.editingBook && idx >= 0){
                const borrowed = books[idx].total - books[idx].quantity;
                if(total < borrowed){
                    alert('Tổng số bản mới không được nhỏ hơn số bản đang được mượn');
                    return;
                }
                books[idx] = { id, name, author, category, total, quantity, desc };
            }else{
                if(idx >= 0){
                    alert('Mã sách đã tồn tại');
                    return;
                }
                books.push({ id, name, author, category, total, quantity, desc });
            }

            saveBooks(books);
            closeModal();
            renderApp();
        }

        function deleteBook(id){
            const user = currentUser();
            if(user.role !== 'librarian') return;
            const book = getBooks().find(b => b.id === id);
            if(!book) return;
            const receipts = getReceipts().filter(r => r.bookId === id && r.status === 'borrowing' && r.qty > r.returnedQty);
            if(receipts.length > 0){
                alert('Không thể xoá vì vẫn còn phiếu mượn đang hoạt động');
                return;
            }
            if(!confirm(`Xoá sách ${book.name}?`)) return;
            saveBooks(getBooks().filter(b => b.id !== id));
            closeModal();
            renderApp();
        }

        function openBorrowModal(bookId){
            const user = currentUser();
            if(user.role !== 'user') return;
            const book = getBooks().find(b => b.id === bookId);
            if(!book) return;
            if(book.quantity <= 0){
                alert('Sách đã hết');
                return;
            }
            state.borrowBookId = bookId;
            const defaultDate = toDateInput(addDays(new Date(), 7));
            openModal(`
                <div class="modal-card">
                    <div class="modal-header">
                        <h3>Mượn sách</h3>
                        <button class="btn btn-ghost" onclick="closeModal()">Đóng</button>
                    </div>
                    <div class="panel" style="margin:0 0 14px;background:#fffaf0">
                        <b>${escapeHtml(book.name)}</b>
                        <div class="small">Mã: ${escapeHtml(book.id)} · Tác giả: ${escapeHtml(book.author)} · Còn ${book.quantity}/${book.total} bản</div>
                        <div class="meta">${escapeHtml(book.desc || '')}</div>
                    </div>
                    <div class="form-grid">
                        <input id="borrowQty" class="field" type="number" min="1" max="${book.quantity}" value="1" placeholder="Số lượng mượn">
                        <input id="borrowDue" class="field" type="date" value="${defaultDate}">
                    </div>
                    <div class="small" style="margin-top:8px">Chọn số lượng và ngày hẹn trả. Phiếu mượn sẽ được tạo ngay sau khi xác nhận.</div>
                    <div class="modal-actions">
                        <button class="btn btn-primary" onclick="confirmBorrow()">Xác nhận mượn</button>
                    </div>
                </div>
            `);
        }

        function confirmBorrow(){
            const user = currentUser();
            if(user.role !== 'user') return;

            const bookId = state.borrowBookId;
            const books = getBooks();
            const book = books.find(b => b.id === bookId);
            if(!book) return;

            const qty = Number(document.getElementById('borrowQty').value);
            const dueDate = document.getElementById('borrowDue').value;

            if(!Number.isInteger(qty) || qty <= 0){
                alert('Số lượng mượn không hợp lệ');
                return;
            }
            if(qty > book.quantity){
                alert('Không đủ số lượng trong kho');
                return;
            }
            if(!dueDate){
                alert('Vui lòng chọn ngày hẹn trả');
                return;
            }
            const due = new Date(dueDate + 'T00:00:00');
            const today = startOfDay(new Date());
            if(due < today){
                alert('Ngày hẹn trả không hợp lệ');
                return;
            }

            book.quantity -= qty;

            const receipt = normalizeReceipt({
                id:`PM-${Date.now()}-${Math.floor(Math.random()*1000)}`,
                username:user.username,
                fullName:user.fullName || user.username,
                bookId:book.id,
                title:book.name,
                qty,
                returnedQty:0,
                borrowDate:toDateInput(new Date()),
                dueDate,
                status:'borrowing',
                finePaid:0,
                noticeDueSoonSent:false,
                lastOverdueNoticeDay:0,
                returnedAt:''
            });

            const receipts = getReceipts();
            receipts.unshift(receipt);
            saveReceipts(receipts);

            const users = getUsers();
            const uidx = users.findIndex(u => u.username === user.username);
            if(uidx >= 0){
                users[uidx].inbox = Array.isArray(users[uidx].inbox) ? users[uidx].inbox : [];
                users[uidx].inbox.unshift({ text:`Mượn sách thành công: ${book.name} (${qty} bản). Phiếu mượn: ${receipt.id}. Hẹn trả vào ${dueDate}.`, at:new Date().toISOString() });
                saveUsers(users);
            }

            notifyRole('librarian', `Có phiếu mượn mới: ${receipt.id} · ${receipt.fullName} mượn ${receipt.title} (${qty} bản) · Hẹn trả ${dueDate}.`);
            syncBorrowedFromReceipts();
            saveBooks(books);
            state.borrowBookId = null;
            closeModal();
            syncReminders();
            renderApp();
        }

        function notifyRole(role, text){
            const users = getUsers();
            users.forEach(u => {
                if(u.role === role){
                    u.inbox = Array.isArray(u.inbox) ? u.inbox : [];
                    u.inbox.unshift({ text, at:new Date().toISOString() });
                }
            });
            saveUsers(users);
        }

        function openReturnModal(receiptId){
            const user = currentUser();
            const receipt = getReceipts().find(r => r.id === receiptId && r.username === user.username);
            if(!receipt) return;
            const remaining = receipt.qty - receipt.returnedQty;
            if(remaining <= 0) return;

            const today = startOfDay(new Date());
            const due = new Date(receipt.dueDate + 'T00:00:00');
            const overdueDays = Math.max(0, daysBetween(due, today));
            const fine = overdueDays * remaining * FINE_PER_DAY;

            state.returnReceiptId = receiptId;
            openModal(`
                <div class="modal-card">
                    <div class="modal-header">
                        <h3>Trả sách</h3>
                        <button class="btn btn-ghost" onclick="closeModal()">Đóng</button>
                    </div>
                    <div class="panel" style="margin:0 0 14px;background:#fffaf0">
                        <b>${escapeHtml(receipt.title)}</b>
                        <div class="small">Phiếu: ${receipt.id} · Còn lại: ${remaining} bản · Hẹn trả: ${receipt.dueDate}</div>
                        <div class="meta">Tiền phạt tạm tính: ${formatMoney(fine)}</div>
                    </div>
                    <div class="form-grid">
                        <input id="returnQty" class="field" type="number" min="1" max="${remaining}" value="${remaining}" placeholder="Số lượng trả">
                        <input id="returnNote" class="field" placeholder="Ghi chú nếu có">
                    </div>
                    <div class="modal-actions">
                        <button class="btn btn-primary" onclick="confirmReturn()">Xác nhận trả</button>
                    </div>
                </div>
            `);
        }

        function confirmReturn(){
            const user = currentUser();
            if(user.role !== 'user') return;

            const receiptId = state.returnReceiptId;
            const receipts = getReceipts();
            const receipt = receipts.find(r => r.id === receiptId && r.username === user.username);
            if(!receipt) return;

            const qty = Number(document.getElementById('returnQty').value);
            const remaining = receipt.qty - receipt.returnedQty;
            if(!Number.isInteger(qty) || qty <= 0 || qty > remaining){
                alert('Số lượng trả không hợp lệ');
                return;
            }

            const books = getBooks();
            const book = books.find(b => b.id === receipt.bookId);
            if(book) book.quantity += qty;

            const today = startOfDay(new Date());
            const due = new Date(receipt.dueDate + 'T00:00:00');
            const overdueDays = Math.max(0, daysBetween(due, today));
            const fine = overdueDays * qty * FINE_PER_DAY;

            receipt.returnedQty += qty;
            receipt.finePaid = Number(receipt.finePaid || 0) + fine;

            if(receipt.returnedQty >= receipt.qty){
                receipt.status = 'returned';
                receipt.returnedAt = toDateInput(new Date());
            }

            saveReceipts(receipts);
            saveBooks(books);

            const users = getUsers();
            const uidx = users.findIndex(u => u.username === user.username);
            if(uidx >= 0){
                users[uidx].inbox = Array.isArray(users[uidx].inbox) ? users[uidx].inbox : [];
                users[uidx].inbox.unshift({
                    text:`Trả sách thành công: ${receipt.title} (${qty} bản). ${fine > 0 ? `Tiền phạt: ${formatMoney(fine)}.` : 'Không có tiền phạt.'}`,
                    at:new Date().toISOString()
                });
                saveUsers(users);
            }

            notifyRole('librarian', `Phiếu trả sách: ${receipt.id} · ${receipt.fullName} trả ${qty} bản của ${receipt.title}. ${fine > 0 ? `Phạt ${formatMoney(fine)}.` : ''}`);
            syncBorrowedFromReceipts();
            state.returnReceiptId = null;
            closeModal();
            syncReminders();
            renderApp();
        }

        function extendBorrow(receiptId){
            const user = currentUser();
            if(user.role !== 'user') return;
            const receipts = getReceipts();
            const receipt = receipts.find(r => r.id === receiptId && r.username === user.username);
            if(!receipt || receipt.status !== 'borrowing') return;

            const days = Number(prompt('Nhập số ngày gia hạn', '7'));
            if(!Number.isInteger(days) || days <= 0 || days > 30){
                alert('Số ngày gia hạn không hợp lệ');
                return;
            }

            const newDue = addDays(new Date(receipt.dueDate + 'T00:00:00'), days);
            receipt.dueDate = toDateInput(newDue);
            receipt.noticeDueSoonSent = false;
            receipt.lastOverdueNoticeDay = 0;

            saveReceipts(receipts);
            syncBorrowedFromReceipts();

            const users = getUsers();
            const uidx = users.findIndex(u => u.username === user.username);
            if(uidx >= 0){
                users[uidx].inbox.unshift({ text:`Gia hạn phiếu ${receipt.id} thêm ${days} ngày. Hạn mới: ${receipt.dueDate}.`, at:new Date().toISOString() });
                saveUsers(users);
            }

            notifyRole('librarian', `Phiếu ${receipt.id} của ${receipt.fullName} đã được gia hạn đến ${receipt.dueDate}.`);
            renderApp();
        }

