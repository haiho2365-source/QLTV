        function receiptCardTemplateUser(r){
            const remaining = r.qty - r.returnedQty;
            const today = startOfDay(new Date());
            const due = new Date(r.dueDate + 'T00:00:00');
            const overdueDays = Math.max(0, daysBetween(due, today));
            const tagClass = r.status === 'returned' ? 'tag-ok' : overdueDays > 0 ? 'tag-bad' : daysBetween(today, due) <= 3 ? 'tag-warn' : 'tag-ok';
            const tagText = r.status === 'returned' ? 'Đã trả' : overdueDays > 0 ? `Quá hạn ${overdueDays} ngày` : daysBetween(today, due) <= 3 ? 'Sắp đến hạn' : 'Đang mượn';
            const fine = overdueDays * remaining * FINE_PER_DAY;
            return `
                <div class="card" style="margin-bottom:12px" onclick="showReceiptDetail('${escapeAttr(r.id)}')">
                    <div class="badge ${tagClass}">${tagText}</div>
                    <div class="card-title">${escapeHtml(r.title)}</div>
                    <div class="meta">Mã phiếu: ${escapeHtml(r.id)}</div>
                    <div class="meta">Số lượng: ${r.qty}</div>
                    <div class="meta">Đã trả: ${r.returnedQty}</div>
                    <div class="meta">Ngày hẹn trả: ${r.dueDate}</div>
                    <div class="meta">Trạng thái: ${escapeHtml(r.status)}</div>
                    <div class="meta">Tiền phạt tạm tính: ${formatMoney(fine)}</div>
                </div>
            `;
        }

