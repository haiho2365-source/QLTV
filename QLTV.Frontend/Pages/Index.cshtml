        function allReceipts(){
            return getReceipts();
        }

        function countActiveReceipts(){
            return allReceipts().filter(r => r.status === 'borrowing' && r.qty > r.returnedQty).length;
        }

        function countOverdueReceipts(){
            const today = startOfDay(new Date());
            return allReceipts().filter(r => {
                if(r.status !== 'borrowing') return false;
                if(r.qty <= r.returnedQty) return false;
                return daysBetween(today, new Date(r.dueDate + 'T00:00:00')) < 0;
            }).length;
        }

        function calculateTotalFine(){
            const today = startOfDay(new Date());
            return allReceipts().reduce((sum, r) => {
                if(r.status !== 'borrowing' || r.qty <= r.returnedQty) return sum;
                const remaining = r.qty - r.returnedQty;
                const due = new Date(r.dueDate + 'T00:00:00');
                const overdueDays = Math.max(0, daysBetween(due, today));
                return sum + overdueDays * remaining * FINE_PER_DAY;
            }, 0);
        }

        function renderSummary(user){
            const books = getBooks();
            const receipts = allReceipts();
            const totalBooks = books.length;
            const totalStock = books.reduce((s,b) => s + Number(b.total || 0), 0);
            const available = books.reduce((s,b) => s + Number(b.quantity || 0), 0);
            const borrowedCount = totalStock - available;

            let items = [];
            if(user.role === 'user'){
                const my = receipts.filter(r => r.username === user.username);
                const active = my.filter(r => r.status === 'borrowing' && r.qty > r.returnedQty).length;
                const overdue = my.filter(r => {
                    if(r.status !== 'borrowing' || r.qty <= r.returnedQty) return false;
                    return daysBetween(startOfDay(new Date()), new Date(r.dueDate + 'T00:00:00')) < 0;
                }).length;
                const fine = my.reduce((sum, r) => {
                    if(r.status !== 'borrowing' || r.qty <= r.returnedQty) return sum;
                    const remaining = r.qty - r.returnedQty;
                    const overdueDays = Math.max(0, daysBetween(new Date(r.dueDate + 'T00:00:00'), startOfDay(new Date())));
                    return sum + overdueDays * remaining * FINE_PER_DAY;
                }, 0);
                items = [
                    ['Sách đang mượn', active, 'Phiếu mượn còn hiệu lực'],
                    ['Quá hạn', overdue, 'Cần trả sớm'],
                    ['Tiền phạt', formatMoney(fine), 'Tạm tính theo ngày'],
                    ['Thông báo', user.inbox.length, 'Hòm thư cá nhân']
                ];
            }else if(user.role === 'librarian'){
                items = [
                    ['Đầu sách', totalBooks, 'Sách đang quản lý'],
                    ['Bản còn lại', available, 'Trong kho hiện có'],
                    ['Đang mượn', borrowedCount, 'Số bản đã xuất'],
                    ['Quá hạn', countOverdueReceipts(), 'Cần nhắc trả']
                ];
            }else{
                const librarians = getUsers().filter(u => u.role === 'librarian').length;
                const reports = getReports().length;
                items = [
                    ['Thủ thư', librarians, 'Tài khoản thủ thư'],
                    ['Đầu sách', totalBooks, 'Sách trong hệ thống'],
                    ['Phiếu mượn', receipts.length, 'Tất cả phiếu'],
                    ['Báo cáo', reports, 'Báo cáo giả lập']
                ];
            }
            document.getElementById('summaryRow').innerHTML = items.map(([label, value, foot]) => `
                <div class="stat-card">
                    <div class="label">${label}</div>
                    <div class="value">${value}</div>
                    <div class="foot">${foot}</div>
                </div>
            `).join('');
        }

