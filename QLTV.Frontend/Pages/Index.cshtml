        function filteredSortedBooks(){
            const key = state.search.trim().toLowerCase();
            const books = getBooks().filter(b => {
                if(!key) return true;
                return [b.id,b.name,b.author,b.category].some(v => String(v).toLowerCase().includes(key));
            });
            books.sort((a,b) => {
                if(state.sort === 'name-asc') return a.name.localeCompare(b.name, 'vi');
                if(state.sort === 'name-desc') return b.name.localeCompare(a.name, 'vi');
                if(state.sort === 'code-asc') return a.id.localeCompare(b.id, 'vi');
                if(state.sort === 'code-desc') return b.id.localeCompare(a.id, 'vi');
                return 0;
            });
            return books;
        }

