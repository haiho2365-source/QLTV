@page
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Library Management</title>
    <style>
        :root {
            --red: #d62828;
            --red2: #b71c1c;
            --yellow: #ffd54f;
            --bg: #f8f8f8;
            --card: #ffffff;
            --text: #1f1f1f;
            --muted: #666;
            --line: #ececec
        }

        * {
            box-sizing: border-box
        }

        body {
            margin: 0;
            font-family: Arial,Helvetica,sans-serif;
            background: linear-gradient(180deg,#fff 0%,#fff7e0 100%);
            color: var(--text)
        }

        .hidden {
            display: none !important
        }

        .screen {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px
        }

        .auth-card {
            width: min(430px,100%);
            background: var(--card);
            border-radius: 22px;
            box-shadow: 0 18px 50px rgba(0,0,0,.12);
            padding: 26px;
            border: 1px solid rgba(214,40,40,.12)
        }

            .auth-card h1, .auth-card h2 {
                margin: 0 0 14px
            }

            .auth-card .muted {
                color: var(--muted);
                font-size: 14px;
                margin-bottom: 12px
            }

        .role-row {
            display: flex;
            gap: 12px;
            margin-top: 14px
        }

        button, input, select, textarea {
            font: inherit
        }

        .btn {
            border: none;
            border-radius: 14px;
            padding: 12px 16px;
            cursor: pointer;
            transition: .2s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px
        }

            .btn:hover {
                transform: translateY(-1px);
                filter: saturate(1.05)
            }

            .btn:disabled {
                opacity: .55;
                cursor: not-allowed;
                transform: none
            }

        .btn-primary {
            background: var(--red);
            color: #fff
        }

            .btn-primary:hover {
                background: var(--yellow);
                color: #1c1c1c
            }

        .btn-ghost {
            background: #fff;
            border: 1px solid #ddd;
            color: #333
        }

            .btn-ghost:hover {
                background: var(--yellow);
                border-color: var(--yellow)
            }

        .btn-soft {
            background: #fff6f6;
            border: 1px solid #f3c7c7;
            color: var(--red2)
        }

            .btn-soft:hover {
                background: var(--yellow);
                color: #1c1c1c;
                border-color: var(--yellow)
            }

        .field {
            width: 100%;
            border: 1px solid #e2e2e2;
            border-radius: 14px;
            padding: 12px 14px;
            margin: 8px 0;
            background: #fff;
            outline: none;
            transition: .2s
        }

            .field:focus {
                border-color: var(--red);
                box-shadow: 0 0 0 4px rgba(214,40,40,.08)
            }

        .link-row {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            margin-top: 12px;
            font-size: 14px;
            flex-wrap: wrap
        }

            .link-row a {
                color: var(--red2);
                text-decoration: none;
                font-weight: 700;
                cursor: pointer
            }

                .link-row a:hover {
                    color: #000;
                    text-decoration: underline
                }

        .topbar {
            height: 74px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 22px;
            border-bottom: 1px solid var(--line);
            position: sticky;
            top: 0;
            z-index: 5;
            box-shadow: 0 2px 18px rgba(0,0,0,.04)
        }

        .brand {
            font-size: 22px;
            font-weight: 900;
            color: var(--red2);
            letter-spacing: .2px
        }

        .brand-sub {
            font-size: 13px;
            color: var(--muted);
            margin-top: 4px
        }

        .session-chip {
            padding: 10px 14px;
            border-radius: 999px;
            background: #fff6f6;
            border: 1px solid #f3cece;
            color: var(--red2);
            font-weight: 700
        }

        .layout {
            display: flex;
            min-height: calc(100vh - 74px)
        }

        .sidebar {
            width: 260px;
            background: linear-gradient(180deg,#fff 0%,#fff8e6 100%);
            border-right: 1px solid var(--line);
            padding: 18px 14px;
            display: flex;
            flex-direction: column;
            gap: 10px
        }

        .nav-btn {
            width: 100%;
            justify-content: flex-start;
            background: #fff;
            border: 1px solid #eee;
            color: #222;
            padding: 13px 14px;
            border-radius: 16px;
            font-weight: 700;
            margin-bottom: 8px
        }

            .nav-btn:hover, .nav-btn.active {
                background: var(--red);
                color: #fff;
                border-color: var(--red)
            }

        .nav-bottom {
            margin-top: auto;
            padding-top: 12px;
            border-top: 1px dashed #ead6d6
        }

        .main {
            flex: 1;
            padding: 22px;
            overflow: auto
        }

        .grid-stats {
            display: grid;
            grid-template-columns: repeat(4,minmax(0,1fr));
            gap: 14px;
            margin-bottom: 18px
        }

        .stat-card {
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 20px;
            padding: 18px;
            box-shadow: 0 10px 30px rgba(0,0,0,.05)
        }

            .stat-card .label {
                color: var(--muted);
                font-size: 13px;
                margin-bottom: 8px
            }

            .stat-card .value {
                font-size: 28px;
                font-weight: 900;
                color: var(--red2)
            }

            .stat-card .foot {
                margin-top: 6px;
                font-size: 13px;
                color: var(--muted)
            }

        .panel {
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 22px;
            padding: 18px;
            box-shadow: 0 10px 30px rgba(0,0,0,.05);
            margin-bottom: 18px
        }

        .panel-title {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 14px
        }

            .panel-title h3 {
                margin: 0
            }

        .toolbar {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center
        }

        .search {
            min-width: 280px;
            flex: 1
        }

        .select {
            min-width: 190px
        }

        .book-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(250px,1fr));
            gap: 14px
        }

        .card {
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 18px;
            padding: 16px;
            box-shadow: 0 8px 22px rgba(0,0,0,.04);
            display: flex;
            flex-direction: column;
            gap: 10px;
            transition: .2s;
            cursor: pointer
        }

            .card:hover {
                transform: translateY(-2px);
                border-color: #f0c98d;
                box-shadow: 0 14px 28px rgba(0,0,0,.08)
            }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 10px;
            border-radius: 999px;
            background: #fff8da;
            border: 1px solid #ffe48f;
            color: #8c6500;
            font-size: 12px;
            font-weight: 700;
            width: max-content
        }

        .card-title {
            font-size: 18px;
            font-weight: 900;
            color: #222;
            line-height: 1.25
        }

        .meta {
            font-size: 13px;
            color: var(--muted);
            line-height: 1.55
        }

        .actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-top: auto
        }

            .actions .btn {
                flex: 1
            }

        .table {
            width: 100%;
            border-collapse: collapse;
            overflow: hidden;
            border-radius: 16px
        }

            .table th, .table td {
                padding: 12px 10px;
                border-bottom: 1px solid #f0f0f0;
                text-align: left;
                font-size: 14px;
                vertical-align: top
            }

            .table th {
                background: #fff7f7;
                color: #7f1010;
                font-size: 13px;
                text-transform: uppercase;
                letter-spacing: .4px
            }

            .table tr:hover td {
                background: #fffef7
            }

        .two-col {
            display: grid;
            grid-template-columns: 1.2fr .8fr;
            gap: 14px
        }

        .small {
            font-size: 13px;
            color: var(--muted)
        }

        .subgrid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(220px,1fr));
            gap: 12px
        }

        .input-row {
            display: grid;
            grid-template-columns: repeat(2,minmax(0,1fr));
            gap: 10px
        }

        .form-title {
            margin: 0 0 8px;
            font-size: 18px
        }

        .hr {
            height: 1px;
            background: #eee;
            margin: 14px 0
        }

        .notice-list {
            display: flex;
            flex-direction: column;
            gap: 10px
        }

        .notice-item {
            padding: 12px 14px;
            border-radius: 14px;
            border: 1px solid #eee;
            background: #fff
        }

            .notice-item .time {
                font-size: 12px;
                color: var(--muted);
                margin-top: 4px
            }

        .empty {
            padding: 30px 16px;
            text-align: center;
            color: var(--muted)
        }

        .tag {
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
            display: inline-flex;
            width: max-content
        }

        .tag-ok {
            background: #e7f7ea;
            color: #176b25
        }

        .tag-warn {
            background: #fff2d7;
            color: #9a5a00
        }

        .tag-bad {
            background: #ffe4e4;
            color: #b40000
        }

        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 20
        }

        .modal {
            position: fixed;
            inset: 0;
            z-index: 21;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 18px
        }

        .modal-card {
            width: min(720px,100%);
            background: #fff;
            border-radius: 22px;
            box-shadow: 0 18px 60px rgba(0,0,0,.25);
            padding: 20px;
            border: 1px solid #eee;
            max-height: 92vh;
            overflow: auto
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            margin-bottom: 14px
        }

            .modal-header h3 {
                margin: 0
            }

        .modal-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: flex-end;
            margin-top: 16px
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2,minmax(0,1fr));
            gap: 10px
        }

        textarea.field {
            min-height: 100px;
            resize: vertical
        }
        
      
    </style>
</head>
<body>

    <div id="roleScreen" class="screen">
        <div class="auth-card">
            <h1>Library Management</h1>
            <div class="muted">Chọn loại tài khoản trước khi đăng nhập</div>
            <div class="role-row">
                <button class="btn btn-primary" onclick="chooseRole('user')">Người dùng</button>
                <button class="btn btn-ghost" onclick="chooseRole('librarian')">Thủ thư</button>
                <button class="btn btn-ghost" onclick="chooseRole('admin')">Admin</button>
            </div>
        </div>
    </div>

    <div id="loginScreen" class="screen hidden">
        <div class="auth-card">
            <div class="modal-header" style="margin-bottom:10px">
                <div>
                    <div class="badge" id="roleBadge">Người dùng</div>
                </div>
                <button class="btn btn-ghost" onclick="backToRole()">Đổi loại</button>
            </div>
            <h2>Đăng nhập</h2>
            <input id="loginUsername" class="field" placeholder="Tên đăng nhập">
            <input id="loginPassword" class="field" type="password" placeholder="Mật khẩu">
            <button class="btn btn-primary" style="width:100%;margin-top:6px" onclick="login()">Đăng nhập</button>
            <div class="link-row">
                <a id="registerLink" href="#" onclick="openRegister();return false">Đăng ký</a>
                <a href="#" onclick="forgotPassword();return false">Quên mật khẩu</a>
            </div>
        </div>
    </div>

    <div id="registerScreen" class="screen hidden">
        <div class="auth-card">
            <div class="modal-header" style="margin-bottom:10px">
                <div class="badge">Đăng ký người dùng</div>
                <button class="btn btn-ghost" onclick="backToLogin()">Quay lại</button>
            </div>
            <h2>Tạo tài khoản</h2>
            <input id="regUsername" class="field" placeholder="Tên tài khoản">
            <input id="regFullName" class="field" placeholder="Họ và tên">
            <input id="regEmail" class="field" placeholder="Email">
            <input id="regPassword" class="field" type="password" placeholder="Mật khẩu">
            <input id="regConfirm" class="field" type="password" placeholder="Xác nhận mật khẩu">
            <button class="btn btn-primary" style="width:100%;margin-top:6px" onclick="register()">Đăng ký</button>
        </div>
    </div>

    <div id="appScreen" class="hidden">
        <div class="topbar">
            <div>
                <div class="brand">Library Management</div>
                <div class="brand-sub">Giao diện quản lý sách, tài khoản, phiếu mượn và báo cáo</div>
            </div>
            <div class="session-chip" id="sessionInfo"></div>
        </div>
        <div class="layout">
            <aside class="sidebar">
                <div id="sidebarButtons"></div>
                <div class="nav-bottom">
                    <button class="btn nav-btn" onclick="logout()">Đăng xuất</button>
                </div>
            </aside>
            <main class="main">
                <div id="summaryRow" class="grid-stats"></div>
                <div id="workspace"></div>
            </main>
        </div>
    </div>

    <div id="modalOverlay" class="modal-overlay hidden" onclick="closeModal()"></div>
    <div id="modalBox" class="modal hidden"></div>

    <script>
        const MS_DAY = 24 * 60 * 60 * 1000;
        const FINE_PER_DAY = 5000;

        const seedBooks = [
            { id:'B01', name:'Harry Potter', author:'J.K. Rowling', category:'Fantasy', total:5, quantity:5, desc:'Câu chuyện về cậu bé phù thủy Harry Potter và hành trình chống lại Chúa tể Voldemort.' },
            { id:'B02', name:'Doraemon', author:'Fujiko F. Fujio', category:'Comic', total:10, quantity:10, desc:'Bộ truyện nổi tiếng về chú mèo máy Doraemon đến từ tương lai giúp đỡ Nobita.' },
            { id:'B03', name:'Sherlock Holmes', author:'Arthur Conan Doyle', category:'Detective', total:7, quantity:7, desc:'Tuyển tập những vụ án trinh thám hấp dẫn của thám tử Sherlock Holmes.' },
            { id:'B04', name:'One Piece', author:'Eiichiro Oda', category:'Manga', total:12, quantity:12, desc:'Hành trình trở thành Vua Hải Tặc của Monkey D. Luffy cùng băng Mũ Rơm.' },
            { id:'B05', name:'Naruto', author:'Masashi Kishimoto', category:'Manga', total:9, quantity:9, desc:'Câu chuyện về ninja Naruto và ước mơ trở thành Hokage của Làng Lá.' },
            { id:'B06', name:'Clean Code', author:'Robert C. Martin', category:'IT', total:4, quantity:4, desc:'Cuốn sách nổi tiếng về cách viết mã sạch, rõ ràng và dễ bảo trì.' },
            { id:'B07', name:'The Hobbit', author:'J.R.R. Tolkien', category:'Fantasy', total:6, quantity:6, desc:'Hành trình phiêu lưu của Bilbo Baggins cùng kho báu và rồng Smaug.' },
            { id:'B08', name:'C++ Primer', author:'Stanley B. Lippman', category:'IT', total:8, quantity:8, desc:'Sách nền tảng giúp học và luyện kỹ năng lập trình C++.' },
            { id:'B09', name:'Python Crash Course', author:'Eric Matthes', category:'IT', total:5, quantity:5, desc:'Lộ trình học Python từ cơ bản đến thực hành một cách nhanh và dễ hiểu.' },
            { id:'B10', name:'Database Systems', author:'Ramez Elmasri', category:'IT', total:3, quantity:3, desc:'Giới thiệu nguyên lý thiết kế và quản trị cơ sở dữ liệu.' },
            { id:'B11', name:'Atomic Habits', author:'James Clear', category:'Self-help', total:6, quantity:6, desc:'Cuốn sách về xây dựng thói quen nhỏ để tạo ra thay đổi lớn trong cuộc sống.' },
            { id:'B12', name:'Rich Dad Poor Dad', author:'Robert Kiyosaki', category:'Finance', total:7, quantity:7, desc:'Những bài học tài chính cá nhân dễ hiểu và thực tế.' },
            { id:'B13', name:'Think and Grow Rich', author:'Napoleon Hill', category:'Finance', total:5, quantity:5, desc:'Tác phẩm kinh điển về tư duy thành công và phát triển bản thân.' },
            { id:'B14', name:'Sapiens', author:'Yuval Noah Harari', category:'History', total:4, quantity:4, desc:'Lịch sử loài người được kể lại dưới góc nhìn bao quát và thú vị.' },
            { id:'B15', name:'1984', author:'George Orwell', category:'Novel', total:6, quantity:6, desc:'Tác phẩm phản địa đàng nổi tiếng về xã hội bị giám sát chặt chẽ.' },
            { id:'B16', name:'The Alchemist', author:'Paulo Coelho', category:'Novel', total:8, quantity:8, desc:'Một hành trình tìm kiếm ước mơ và ý nghĩa cuộc sống.' },
            { id:'B17', name:'To Kill a Mockingbird', author:'Harper Lee', category:'Novel', total:3, quantity:3, desc:'Câu chuyện về công lý, lòng nhân ái và tuổi thơ.' },
            { id:'B18', name:'A Game of Thrones', author:'George R. R. Martin', category:'Fantasy', total:5, quantity:5, desc:'Cuộc tranh giành quyền lực gay cấn trong một thế giới giả tưởng rộng lớn.' },
            { id:'B19', name:'War and Peace', author:'Leo Tolstoy', category:'Classic', total:2, quantity:2, desc:'Tác phẩm kinh điển khắc họa chiến tranh, hòa bình và số phận con người.' },
            { id:'B20', name:'The Great Gatsby', author:'F. Scott Fitzgerald', category:'Classic', total:4, quantity:4, desc:'Bức tranh sống động về xã hội và những giấc mơ Mỹ.' }
        ];

        const seedUsers = [
            {
                username:'admin',
                password:'123',
                role:'admin',
                fullName:'Quản trị viên',
                email:'admin@library.local',
                phone:'',
                inbox:[],
                borrowed:[]
            },
            {
                username:'thu_thu',
                password:'123',
                role:'librarian',
                fullName:'Thủ thư mẫu',
                email:'thuthu@library.local',
                phone:'',
                inbox:[],
                borrowed:[]
            }
        ];

        const seedReports = [
            { title:'Báo cáo tuần', content:'Tổng số phiếu mượn trong tuần này tăng 12% so với tuần trước.' },
            { title:'Báo cáo kho', content:'5 đầu sách đang ở mức tồn kho thấp cần bổ sung thêm.' },
            { title:'Báo cáo quá hạn', content:'Có 3 phiếu mượn quá hạn cần nhắc nhở và xử lý phạt.' }
        ];

        let state = {
            role:'user',
            tab:'books',
            search:'',
            sort:'name-asc',
            editingBook:null,
            editingUser:null,
            borrowBookId:null,
            returnReceiptId:null,
            otpTarget:null,
            otpCode:null,
            otpPurpose:null
        };

        function cloneData(data){
            return JSON.parse(JSON.stringify(data));
        }

        function loadJSON(key, fallback){
            const raw = localStorage.getItem(key);
            if(!raw) return cloneData(fallback);
            try{
                return JSON.parse(raw);
            }catch{
                return cloneData(fallback);
            }
        }

        function saveJSON(key, value){
            localStorage.setItem(key, JSON.stringify(value));
        }

        function normalizeBooks(){
            let books = loadJSON('books', seedBooks);
            books = books.map((b, i) => ({
                id: String(b.id || `B${String(i + 1).padStart(2,'0')}`),
                name: b.name || 'Không tên',
                author: b.author || '',
                category: b.category || '',
                total: Number.isFinite(Number(b.total)) ? Number(b.total) : Number(b.quantity || 0),
                quantity: Number.isFinite(Number(b.quantity)) ? Number(b.quantity) : Number(b.total || 0),
                desc: b.desc || 'Chưa có mô tả.'
            }));
            books.forEach(b => {
                if(b.quantity > b.total) b.total = b.quantity;
                if(b.quantity < 0) b.quantity = 0;
                if(b.total < 0) b.total = b.quantity;
            });
            saveJSON('books', books);
            return books;
        }

        function normalizeReceipt(r){
            const qty = Number(r.qty ?? r.quantity ?? 1);
            const returnedQty = Number(r.returnedQty ?? 0);
            return {
                id: String(r.id || `PM-${Date.now()}-${Math.floor(Math.random()*1000)}`),
                username: r.username || '',
                fullName: r.fullName || '',
                bookId: r.bookId || '',
                title: r.title || '',
                qty: Number.isFinite(qty) && qty > 0 ? qty : 1,
                returnedQty: Number.isFinite(returnedQty) && returnedQty >= 0 ? returnedQty : 0,
                borrowDate: r.borrowDate || toDateInput(new Date()),
                dueDate: r.dueDate || toDateInput(addDays(new Date(), 7)),
                status: r.status || 'borrowing',
                finePaid: Number(r.finePaid || 0),
                noticeDueSoonSent: !!r.noticeDueSoonSent,
                lastOverdueNoticeDay: Number.isFinite(Number(r.lastOverdueNoticeDay)) ? Number(r.lastOverdueNoticeDay) : 0,
                returnedAt: r.returnedAt || ''
            };
        }

        function normalizeUsers(){
            let users = loadJSON('users', seedUsers);
            users = users.map(u => ({
                username: String(u.username || '').trim(),
                password: String(u.password || ''),
                role: u.role === 'admin' || u.role === 'librarian' ? u.role : 'user',
                fullName: u.fullName || u.username || '',
                email: u.email || '',
                phone: u.phone || '',
                inbox: Array.isArray(u.inbox) ? u.inbox.map(m => typeof m === 'string' ? { text:m, at:new Date().toISOString() } : m) : [],
                borrowed: Array.isArray(u.borrowed) ? u.borrowed.map(normalizeReceipt) : []
            })).filter(u => u.username);

            if(!users.some(u => u.role === 'admin' && u.username === 'admin')){
                users.unshift({
                    username:'admin',
                    password:'123',
                    role:'admin',
                    fullName:'Quản trị viên',
                    email:'admin@library.local',
                    phone:'',
                    inbox:[],
                    borrowed:[]
                });
            }
            if(!users.some(u => u.role === 'librarian' && u.username === 'thu_thu')){
                users.push({
                    username:'thu_thu',
                    password:'123',
                    role:'librarian',
                    fullName:'Thủ thư mẫu',
                    email:'thuthu@library.local',
                    phone:'',
                    inbox:[],
                    borrowed:[]
                });
            }
            saveJSON('users', users);
            return users;
        }

        function normalizeReceipts(){
            let receipts = loadJSON('receipts', []);
            receipts = receipts.map(normalizeReceipt);
            saveJSON('receipts', receipts);
            return receipts;
        }

        function normalizeReports(){
            const reports = loadJSON('reports', seedReports);
            saveJSON('reports', reports);
            return reports;
        }

        function initAppData(){
            normalizeBooks();
            normalizeUsers();
            normalizeReceipts();
            normalizeReports();
            syncBorrowedFromReceipts();
        }

        function getBooks(){ return loadJSON('books', seedBooks); }
        function getUsers(){ return loadJSON('users', seedUsers); }
        function getReceipts(){ return loadJSON('receipts', []); }
        function getReports(){ return loadJSON('reports', seedReports); }

        function saveBooks(books){ saveJSON('books', books); }
        function saveUsers(users){ saveJSON('users', users); }
        function saveReceipts(receipts){ saveJSON('receipts', receipts); }
        function saveReports(reports){ saveJSON('reports', reports); }

        function syncBorrowedFromReceipts(){
            const users = getUsers();
            const receipts = getReceipts();
            users.forEach(u => {
                u.borrowed = receipts.filter(r => r.username === u.username).map(r => cloneData(r));
            });
            saveUsers(users);
        }

